DATABASE_URL="file:./prisma/dev.db"

# Required for NextAuth / Auth.js (sessions, JWT). Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-random-string"

# Optional: Google sign-in — create OAuth client at https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
