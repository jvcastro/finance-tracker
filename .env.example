# PostgreSQL (e.g. Neon). Must start with postgresql:// or postgres://
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js — required for sessions (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-random-string"

# Optional: Google sign-in
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
