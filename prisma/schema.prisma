generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  tags            Tag[]
  banks           Bank[]
  incomeStreams   IncomeStream[]
  incomes         Income[]
  expenses        Expense[]
  creditCardDebts CreditCardDebt[]
  appSettings     AppSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tag {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime  @default(now())
  incomes        Income[]
  incomeStreams  IncomeStream[]
  expenses       Expense[]

  @@unique([userId, name])
}

/// Financial institutions you use (checking, savings, card issuers, etc.).
model Bank {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// Where the income comes from: employer salary, a project, or uncategorized.
enum IncomeSourceType {
  SALARY
  PROJECT
  OTHER
}

/// How often an employer pays (company salary only). ONE_OFF = bonus or single payment.
enum SalaryPaySchedule {
  MONTHLY
  BI_WEEKLY
  ONE_OFF
}

/// Your income source definition (amount, schedule, dates). Does not create ledger rows by itself.
model IncomeStream {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Per payment: monthly salary = one month gross; bi-weekly = one paycheck; project/other = usually monthly.
  amount            Decimal
  sourceType        IncomeSourceType
  sourceName        String?
  salaryPaySchedule SalaryPaySchedule?
  /// Day of month pay lands (1–31); Feb etc. clamp to last day. Not derived from start date.
  paymentDay        Int              @default(15)
  /// Second pay day in the month (e.g. 30); required for bi-weekly salary (e.g. 15 & 30).
  secondPaymentDay  Int?
  startDate         DateTime
  endDate           DateTime?
  description       String?
  tagId             String?
  tag               Tag?               @relation(fields: [tagId], references: [id], onDelete: SetNull)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  incomes           Income[]

  @@index([userId])
}

/// One expected or actual payment: generated from a stream’s pay schedule, or entered manually.
model Income {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeStreamId String?
  incomeStream   IncomeStream? @relation(fields: [incomeStreamId], references: [id], onDelete: Cascade)
  /// Calendar date this payment is for (payday).
  scheduledDate  DateTime
  amount         Decimal
  received       Boolean       @default(false)
  description    String?
  tagId          String?
  tag            Tag?          @relation(fields: [tagId], references: [id], onDelete: SetNull)
  /// Only when incomeStreamId is null (manual entry).
  sourceType        IncomeSourceType?
  sourceName        String?
  salaryPaySchedule SalaryPaySchedule?
  createdAt         DateTime      @default(now())

  @@index([userId])
  @@index([scheduledDate])
  @@unique([incomeStreamId, scheduledDate])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal
  date        DateTime
  description String?
  tagId       String?
  tag         Tag?     @relation(fields: [tagId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model CreditCardDebt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount String
  toAccount   String
  amount      Decimal
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())
}

model AppSettings {
  userId       String @id
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     String @default("USD")
  weekStartsOn Int    @default(0)
}
