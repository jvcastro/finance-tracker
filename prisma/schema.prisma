generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  tags            Tag[]
  banks           Bank[]
  incomes         Income[]
  expenses        Expense[]
  creditCardDebts CreditCardDebt[]
  appSettings     AppSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tag {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime  @default(now())
  incomes   Income[]
  expenses  Expense[]

  @@unique([userId, name])
}

/// Financial institutions you use (checking, savings, card issuers, etc.).
model Bank {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Income {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal
  date        DateTime
  description String?
  tagId       String?
  tag         Tag?     @relation(fields: [tagId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal
  date        DateTime
  description String?
  tagId       String?
  tag         Tag?     @relation(fields: [tagId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model CreditCardDebt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount String
  toAccount   String
  amount      Decimal
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())
}

model AppSettings {
  userId       String @id
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     String @default("USD")
  weekStartsOn Int    @default(0)
}
