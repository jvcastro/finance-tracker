generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  tags              Tag[]
  financialAccounts FinancialAccount[]
  incomeStreams     IncomeStream[]
  expenseStreams    ExpenseStream[]
  incomes           Income[]
  expenses          Expense[]
  creditCardDebts   CreditCardDebt[]
  appSettings       AppSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tag {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  color          String?
  createdAt      DateTime        @default(now())
  incomes        Income[]
  incomeStreams  IncomeStream[]
  expenseStreams ExpenseStream[]
  expenses       Expense[]

  @@unique([userId, name])
}

/// Savings, checking, cards, e-wallets (GCash, Maya), or cash — where money is held or charged.
enum FinancialAccountKind {
  SAVINGS
  CHECKING
  CREDIT_CARD
  E_WALLET
  CASH
}

model FinancialAccount {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  kind           FinancialAccountKind
  notes          String?
  /// Day of month (1–31) the billing statement closes. Only used when kind is CREDIT_CARD.
  creditStatementDay Int?
  /// Day of month (1–31) payment is due. Only used when kind is CREDIT_CARD.
  creditDueDay       Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  expenseStreams ExpenseStream[]
  expenses       Expense[]
  incomeStreams  IncomeStream[]
  incomes        Income[]

  @@index([userId])
}

/// Where the income comes from: employer salary, a project, or uncategorized.
enum IncomeSourceType {
  SALARY
  PROJECT
  OTHER
}

/// How often an employer pays (company salary only). ONE_OFF = bonus or single payment.
enum SalaryPaySchedule {
  MONTHLY
  BI_WEEKLY
  ONE_OFF
}

/// Your income source definition (amount, schedule, dates). Does not create ledger rows by itself.
model IncomeStream {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Per payment: monthly salary = one month gross; bi-weekly = one paycheck; project/other = usually monthly.
  amount             Decimal
  sourceType         IncomeSourceType
  sourceName         String?
  salaryPaySchedule  SalaryPaySchedule?
  /// Day of month pay lands (1–31); Feb etc. clamp to last day. Not derived from start date.
  paymentDay         Int                @default(15)
  /// Second pay day in the month (e.g. 30); required for bi-weekly salary (e.g. 15 & 30).
  secondPaymentDay   Int?
  startDate          DateTime
  endDate            DateTime?
  description        String?
  tagId              String?
  tag                Tag?               @relation(fields: [tagId], references: [id], onDelete: SetNull)
  financialAccountId String?
  financialAccount   FinancialAccount?  @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  incomes            Income[]

  @@index([userId])
}

/// One expected or actual payment: generated from a stream’s pay schedule, or entered manually.
model Income {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeStreamId     String?
  incomeStream       IncomeStream?      @relation(fields: [incomeStreamId], references: [id], onDelete: Cascade)
  /// Calendar date this payment is for (payday).
  scheduledDate      DateTime
  amount             Decimal
  received           Boolean            @default(false)
  description        String?
  tagId              String?
  tag                Tag?               @relation(fields: [tagId], references: [id], onDelete: SetNull)
  financialAccountId String?
  financialAccount   FinancialAccount?  @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  /// Only when incomeStreamId is null (manual entry).
  sourceType         IncomeSourceType?
  sourceName         String?
  salaryPaySchedule  SalaryPaySchedule?
  /// R2 object key for receipt/invoice (image or PDF).
  attachmentKey      String?
  attachmentMime     String?
  createdAt          DateTime           @default(now())

  @@unique([incomeStreamId, scheduledDate])
  @@index([userId])
  @@index([scheduledDate])
}

/// How this expense is typically settled (for your own reference).
enum ExpensePaymentMethod {
  MANUAL
  BANK_AUTO_DEBIT
  CARD_AUTO_PAY
}

/// Monthly recurring expense template (amount, day of month, optional end date).
model ExpenseStream {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount             Decimal
  description        String?
  tagId              String?
  tag                Tag?                 @relation(fields: [tagId], references: [id], onDelete: SetNull)
  financialAccountId String?
  financialAccount   FinancialAccount?    @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  /// e.g. ACH debit vs card autopay vs you pay manually.
  paymentMethod      ExpensePaymentMethod @default(MANUAL)
  /// Day of month the charge occurs (1–31; clamped to last day in month).
  paymentDay         Int                  @default(1)
  startDate          DateTime
  endDate            DateTime?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  expenses           Expense[]

  @@index([userId])
}

model Expense {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount             Decimal
  date               DateTime
  description        String?
  tagId              String?
  tag                Tag?                 @relation(fields: [tagId], references: [id], onDelete: SetNull)
  expenseStreamId    String?
  expenseStream      ExpenseStream?       @relation(fields: [expenseStreamId], references: [id], onDelete: Cascade)
  financialAccountId String?
  financialAccount   FinancialAccount?    @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  /// Mirrors recurring template when generated from a stream.
  paymentMethod      ExpensePaymentMethod @default(MANUAL)
  /// User marked this charge as paid (e.g. settled the card / bill).
  paid               Boolean              @default(false)
  /// R2 object key for receipt/invoice (image or PDF).
  attachmentKey      String?
  attachmentMime     String?
  createdAt          DateTime             @default(now())

  @@unique([expenseStreamId, date])
  @@index([userId])
  @@index([date])
}

model CreditCardDebt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount String
  toAccount   String
  amount      Decimal
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())
}

model AppSettings {
  userId           String  @id
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency         String  @default("PHP")
  weekStartsOn     Int     @default(0)
  /// Per-user dashboard section visibility: `{ "overview": true, "needThisMonth": false, ... }`
  dashboardWidgets Json?
  /// Set true after the user finishes or skips the welcome tour (Driver.js).
  completedAppTour Boolean @default(false)
}
